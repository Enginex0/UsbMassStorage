    <string name="guide_what_title">Ứng dụng này làm gì</string>
    <string name="guide_what_body">Biến điện thoại của bạn thành ổ USB. Khi kết nối với máy tính qua USB, máy tính sẽ nhận diện ảnh đĩa trên điện thoại của bạn như một thiết bị lưu trữ USB thật. Bạn có thể gắn kết tệp .img như USB hoặc tệp .iso như ổ CD.</string>
    <string name="guide_before_title">Trước khi bắt đầu</string>
    <string name="guide_before_1">Cần quyền root (KernelSU, Magisk hoặc APatch)</string>
    <string name="guide_before_2">Cấp quyền root cho ứng dụng này trong trình quản lý root của bạn</string>
    <string name="guide_before_3">Kết nối điện thoại với máy tính bằng cáp USB</string>
    <string name="guide_mount_title">Gắn kết ảnh đĩa</string>
    <string name="guide_mount_1">Nhấn nút + trên màn hình chính</string>
    <string name="guide_mount_2">Nhấn \"Chọn tệp ảnh đĩa\" và chọn tệp .img hoặc .iso của bạn</string>
    <string name="guide_mount_3">Chọn loại: Đọc-Ghi (USB), Chỉ đọc (chống ghi) hoặc CD-ROM (cho tệp ISO)</string>
    <string name="guide_mount_4">Nhấn \"Gắn kết\". Máy tính sẽ phát hiện thiết bị USB mới trong vài giây.</string>
    <string name="guide_mount_5">Để tháo: nhấn biểu tượng tháo trên thẻ thiết bị.</string>
    <string name="guide_create_title">Tạo ảnh đĩa mới</string>
    <string name="guide_create_1">Nhấn +, sau đó \"Tạo ảnh đĩa mới\"</string>
    <string name="guide_create_2">Đặt tên tệp và kích thước (chấp nhận MB, GB, GiB). Tạo ngay lập tức.</string>
    <string name="guide_create_3">Sau khi gắn kết, định dạng từ máy tính (FAT32, exFAT hoặc NTFS).</string>
    <string name="guide_multi_title">Nhiều thiết bị</string>
    <string name="guide_multi_body">Gắn kết tối đa 8 thiết bị cùng lúc. Mỗi thiết bị hiển thị như một thiết bị USB riêng biệt trên máy tính. Nhấn thẻ thiết bị để thay đổi loại hoặc xóa nó.</string>
    <string name="guide_issues_title">Các vấn đề thường gặp</string>
    <string name="guide_issue_daemon">Daemon không chạy</string>
    <string name="guide_issue_daemon_fix">Khởi động lại thiết bị hoặc vào Cài đặt và nhấn Khởi động lại daemon.</string>
    <string name="guide_issue_root">Root chưa được cấp</string>
    <string name="guide_issue_root_fix">Mở trình quản lý root (KSU/Magisk) và cấp quyền root cho ứng dụng này.</string>
    <string name="guide_issue_usb">Máy tính không phát hiện USB</string>
    <string name="guide_issue_usb_fix">Kết nối lại cáp. Kiểm tra xem gỡ lỗi USB có đang ghi đè chế độ gadget không.</string>
    <string name="guide_issue_appfuse">AppFuse proxy</string>
    <string name="guide_issue_appfuse_fix">Trình chọn tệp của bạn đang proxy tệp. Sử dụng trình quản lý tệp khác (không phải Google Files).</string>
