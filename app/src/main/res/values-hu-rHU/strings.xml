    <string name="guide_what_title">Mit csinál ez az alkalmazás</string>
    <string name="guide_what_body">USB-meghajtóvá alakítja a telefonodat. Amikor USB-kábellel csatlakoztatod a számítógéphez, a számítógép a telefonon lévő lemezképet valódi USB-tárolóeszközként látja. Csatolhatsz .img fájlokat pendrive-ként vagy .iso fájlokat CD-meghajtóként.</string>
    <string name="guide_before_title">Mielőtt elkezdenéd</string>
    <string name="guide_before_1">Root hozzáférés szükséges (KernelSU, Magisk vagy APatch)</string>
    <string name="guide_before_2">Add meg az alkalmazásnak a root engedélyt a root kezelőben</string>
    <string name="guide_before_3">Csatlakoztasd a telefonodat USB-kábellel a számítógéphez</string>
    <string name="guide_mount_title">Lemezkép csatolása</string>
    <string name="guide_mount_1">Koppints a + gombra a főképernyőn</string>
    <string name="guide_mount_2">Koppints a \"Lemezkép fájl kiválasztása\" lehetőségre, és válaszd ki a .img vagy .iso fájlt</string>
    <string name="guide_mount_3">Válaszd ki a típust: Írás-Olvasás (pendrive), Csak olvasható (írásvédett) vagy CD-ROM (ISO fájlokhoz)</string>
    <string name="guide_mount_4">Koppints a \"Csatolás\" gombra. A számítógép másodperceken belül észleli az új USB-eszközt.</string>
    <string name="guide_mount_5">Kiadáshoz: koppints a kiadás ikonra az eszközkártyán.</string>
    <string name="guide_create_title">Új lemezkép létrehozása</string>
    <string name="guide_create_1">Koppints a + gombra, majd az \"Új lemezkép létrehozása\" lehetőségre</string>
    <string name="guide_create_2">Add meg a fájlnevet és a méretet (MB, GB, GiB értékeket fogad el). Azonnal létrejön.</string>
    <string name="guide_create_3">Csatolás után formázd meg a számítógépről (FAT32, exFAT vagy NTFS).</string>
    <string name="guide_multi_title">Több eszköz</string>
    <string name="guide_multi_body">Egyszerre akár 8 eszközt is csatolhatsz. Mindegyik külön USB-eszközként jelenik meg a számítógépen. Koppints egy eszközkártyára a típus módosításához vagy az eltávolításhoz.</string>
    <string name="guide_issues_title">Gyakori problémák</string>
    <string name="guide_issue_daemon">Daemon nem fut</string>
    <string name="guide_issue_daemon_fix">Indítsd újra az eszközt, vagy menj a Beállításokba és koppints a Daemon újraindítása lehetőségre.</string>
    <string name="guide_issue_root">Root nincs megadva</string>
    <string name="guide_issue_root_fix">Nyisd meg a root kezelőt (KSU/Magisk), és add meg az alkalmazásnak a root hozzáférést.</string>
    <string name="guide_issue_usb">A számítógép nem észleli az USB-t</string>
    <string name="guide_issue_usb_fix">Csatlakoztasd újra a kábelt. Ellenőrizd, hogy az USB-hibakeresés nem írja-e felül a gadget módot.</string>
    <string name="guide_issue_appfuse">AppFuse proxy</string>
    <string name="guide_issue_appfuse_fix">A fájlválasztó proxyn keresztül éri el a fájlt. Használj másik fájlkezelőt (ne a Google Files-t).</string>
