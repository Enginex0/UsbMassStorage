    <string name="guide_what_title">Hva denne appen gjør</string>
    <string name="guide_what_body">Gjør telefonen din til en USB-stasjon. Når den er koblet til en datamaskin via USB, ser datamaskinen en diskavbildning på telefonen din som en ekte USB-lagringsenhet. Du kan montere .img-filer som USB-minnepinner eller .iso-filer som CD-stasjoner.</string>
    <string name="guide_before_title">Før du begynner</string>
    <string name="guide_before_1">Root-tilgang kreves (KernelSU, Magisk eller APatch)</string>
    <string name="guide_before_2">Gi root-tillatelse til denne appen i root-behandleren din</string>
    <string name="guide_before_3">Koble telefonen til en datamaskin via USB-kabel</string>
    <string name="guide_mount_title">Montere en diskavbildning</string>
    <string name="guide_mount_1">Trykk på +-knappen på hovedskjermen</string>
    <string name="guide_mount_2">Trykk på \"Velg diskavbildningsfil\" og velg din .img eller .iso</string>
    <string name="guide_mount_3">Velg type: Lese-skrive (USB-minnepinne), Skrivebeskyttet (skrivebeskyttet) eller CD-ROM (for ISO-filer)</string>
    <string name="guide_mount_4">Trykk på \"Monter\". Datamaskinen oppdager en ny USB-enhet i løpet av sekunder.</string>
    <string name="guide_mount_5">For å løse ut: trykk på løs ut-ikonet på enhetskortet.</string>
    <string name="guide_create_title">Opprette en ny avbildning</string>
    <string name="guide_create_1">Trykk på +, deretter \"Opprett ny diskavbildning\"</string>
    <string name="guide_create_2">Angi filnavn og størrelse (godtar MB, GB, GiB). Opprettes umiddelbart.</string>
    <string name="guide_create_3">Etter montering, formater den fra datamaskinen (FAT32, exFAT eller NTFS).</string>
    <string name="guide_multi_title">Flere enheter</string>
    <string name="guide_multi_body">Monter opptil 8 enheter samtidig. Hver vises som en separat USB-enhet på datamaskinen. Trykk på et enhetskort for å endre type eller fjerne den.</string>
    <string name="guide_issues_title">Vanlige problemer</string>
    <string name="guide_issue_daemon">Daemon kjører ikke</string>
    <string name="guide_issue_daemon_fix">Start enheten på nytt, eller gå til Innstillinger og trykk Start daemon på nytt.</string>
    <string name="guide_issue_root">Root ikke innvilget</string>
    <string name="guide_issue_root_fix">Åpne root-behandleren din (KSU/Magisk) og gi denne appen root-tilgang.</string>
    <string name="guide_issue_usb">Datamaskinen oppdager ikke USB</string>
    <string name="guide_issue_usb_fix">Koble til kabelen på nytt. Sjekk at USB-feilsøking ikke overstyrer gadget-modus.</string>
    <string name="guide_issue_appfuse">AppFuse-proxy</string>
    <string name="guide_issue_appfuse_fix">Filvelgeren din videresender filen. Bruk en annen filbehandler (ikke Google Filer).</string>
