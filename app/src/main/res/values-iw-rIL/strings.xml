    <string name="guide_what_title">מה האפליקציה עושה</string>
    <string name="guide_what_body">הופכת את הטלפון שלך לכונן USB. כשהוא מחובר למחשב דרך USB, המחשב רואה תמונת דיסק בטלפון שלך כהתקן אחסון USB אמיתי. ניתן לעגון קבצי .img ככונני USB או קבצי .iso ככונני CD.</string>
    <string name="guide_before_title">לפני שמתחילים</string>
    <string name="guide_before_1">נדרשת הרשאת Root (KernelSU, Magisk או APatch)</string>
    <string name="guide_before_2">הענק הרשאת Root לאפליקציה זו במנהל ה-Root שלך</string>
    <string name="guide_before_3">חבר את הטלפון למחשב באמצעות כבל USB</string>
    <string name="guide_mount_title">עגינת תמונת דיסק</string>
    <string name="guide_mount_1">הקש על כפתור + במסך הראשי</string>
    <string name="guide_mount_2">הקש על \"בחירת קובץ תמונת דיסק\" ובחר את קובץ ה-.img או ה-.iso שלך</string>
    <string name="guide_mount_3">בחר סוג: קריאה-כתיבה (כונן USB), קריאה בלבד (מוגן כתיבה), או CD-ROM (לקבצי ISO)</string>
    <string name="guide_mount_4">הקש על \"עגינה\". המחשב מזהה התקן USB חדש תוך שניות.</string>
    <string name="guide_mount_5">לשליפה: הקש על סמל השליפה בכרטיס ההתקן.</string>
    <string name="guide_create_title">יצירת תמונה חדשה</string>
    <string name="guide_create_1">הקש על +, ואז \"יצירת תמונת דיסק חדשה\"</string>
    <string name="guide_create_2">הגדר שם קובץ וגודל (מקבל MB, GB, GiB). נוצר מיידית.</string>
    <string name="guide_create_3">לאחר העגינה, פרמט אותו מהמחשב (FAT32, exFAT או NTFS).</string>
    <string name="guide_multi_title">התקנים מרובים</string>
    <string name="guide_multi_body">עגון עד 8 התקנים בו-זמנית. כל אחד מופיע כהתקן USB נפרד במחשב. הקש על כרטיס ההתקן כדי לשנות את סוגו או להסיר אותו.</string>
    <string name="guide_issues_title">בעיות נפוצות</string>
    <string name="guide_issue_daemon">Daemon לא פועל</string>
    <string name="guide_issue_daemon_fix">הפעל מחדש את המכשיר, או עבור להגדרות והקש על הפעלה מחדש של Daemon.</string>
    <string name="guide_issue_root">הרשאת Root לא ניתנה</string>
    <string name="guide_issue_root_fix">פתח את מנהל ה-Root שלך (KSU/Magisk) והענק לאפליקציה זו הרשאת Root.</string>
    <string name="guide_issue_usb">המחשב לא מזהה USB</string>
    <string name="guide_issue_usb_fix">חבר מחדש את הכבל. ודא שניפוי USB לא דורס את מצב gadget.</string>
    <string name="guide_issue_appfuse">פרוקסי AppFuse</string>
    <string name="guide_issue_appfuse_fix">בורר הקבצים שלך מעביר את הקובץ דרך פרוקסי. השתמש במנהל קבצים אחר (לא Google Files).</string>
