    <string name="guide_what_title">Mitä tämä sovellus tekee</string>
    <string name="guide_what_body">Muuttaa puhelimesi USB-asemaksi. Kun puhelin on yhdistetty tietokoneeseen USB:n kautta, tietokone näkee puhelimesi levykuvan oikeana USB-tallennuslaitteena. Voit liittää .img-tiedostoja USB-muistitikkuina tai .iso-tiedostoja CD-asemina.</string>
    <string name="guide_before_title">Ennen aloittamista</string>
    <string name="guide_before_1">Root-oikeudet vaaditaan (KernelSU, Magisk tai APatch)</string>
    <string name="guide_before_2">Myönnä root-oikeus tälle sovellukselle root-hallinnassasi</string>
    <string name="guide_before_3">Yhdistä puhelimesi tietokoneeseen USB-kaapelilla</string>
    <string name="guide_mount_title">Levykuvan liittäminen</string>
    <string name="guide_mount_1">Napauta +-painiketta päänäytöllä</string>
    <string name="guide_mount_2">Napauta \"Valitse levykuvatiedosto\" ja valitse .img- tai .iso-tiedostosi</string>
    <string name="guide_mount_3">Valitse tyyppi: Luku-kirjoitus (USB-tikku), Vain luku (kirjoitussuojattu) tai CD-ROM (ISO-tiedostoille)</string>
    <string name="guide_mount_4">Napauta \"Liitä\". Tietokone tunnistaa uuden USB-laitteen muutamassa sekunnissa.</string>
    <string name="guide_mount_5">Poistaaksesi: napauta poistokuvaketta laitekortissa.</string>
    <string name="guide_create_title">Uuden levykuvan luominen</string>
    <string name="guide_create_1">Napauta +, sitten \"Luo uusi levykuva\"</string>
    <string name="guide_create_2">Aseta tiedostonimi ja koko (hyväksyy MB, GB, GiB). Luodaan välittömästi.</string>
    <string name="guide_create_3">Liittämisen jälkeen alusta se tietokoneelta (FAT32, exFAT tai NTFS).</string>
    <string name="guide_multi_title">Useita laitteita</string>
    <string name="guide_multi_body">Liitä jopa 8 laitetta samanaikaisesti. Jokainen näkyy erillisenä USB-laitteena tietokoneella. Napauta laitekorttia muuttaaksesi sen tyyppiä tai poistaaksesi sen.</string>
    <string name="guide_issues_title">Yleisiä ongelmia</string>
    <string name="guide_issue_daemon">Daemon ei ole käynnissä</string>
    <string name="guide_issue_daemon_fix">Käynnistä laitteesi uudelleen tai siirry Asetuksiin ja napauta Käynnistä daemon uudelleen.</string>
    <string name="guide_issue_root">Root ei myönnetty</string>
    <string name="guide_issue_root_fix">Avaa root-hallintasi (KSU/Magisk) ja myönnä tälle sovellukselle root-oikeudet.</string>
    <string name="guide_issue_usb">Tietokone ei tunnista USB:ta</string>
    <string name="guide_issue_usb_fix">Kytke kaapeli uudelleen. Tarkista, ettei USB-virheenkorjaus ohita gadget-tilaa.</string>
    <string name="guide_issue_appfuse">AppFuse-välityspalvelin</string>
    <string name="guide_issue_appfuse_fix">Tiedostovalitsimesi välittää tiedoston. Käytä toista tiedostonhallintaa (ei Google Files).</string>
