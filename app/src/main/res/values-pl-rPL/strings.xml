    <string name="guide_what_title">Co robi ta aplikacja</string>
    <string name="guide_what_body">Zamienia telefon w dysk USB. Po podłączeniu do komputera kablem USB komputer widzi obraz dysku na telefonie jako prawdziwe urządzenie pamięci USB. Możesz montować pliki .img jako pendrive\'y lub pliki .iso jako napędy CD.</string>
    <string name="guide_before_title">Zanim zaczniesz</string>
    <string name="guide_before_1">Wymagany dostęp root (KernelSU, Magisk lub APatch)</string>
    <string name="guide_before_2">Przyznaj tej aplikacji uprawnienia root w menedżerze root</string>
    <string name="guide_before_3">Podłącz telefon do komputera kablem USB</string>
    <string name="guide_mount_title">Montowanie obrazu dysku</string>
    <string name="guide_mount_1">Naciśnij przycisk + na ekranie głównym</string>
    <string name="guide_mount_2">Naciśnij \"Wybierz plik obrazu dysku\" i wybierz plik .img lub .iso</string>
    <string name="guide_mount_3">Wybierz typ: Odczyt-Zapis (pendrive), Tylko do odczytu (zabezpieczony przed zapisem) lub CD-ROM (dla plików ISO)</string>
    <string name="guide_mount_4">Naciśnij \"Zamontuj\". Komputer wykryje nowe urządzenie USB w ciągu kilku sekund.</string>
    <string name="guide_mount_5">Aby wysunąć: naciśnij ikonę wysuwania na karcie urządzenia.</string>
    <string name="guide_create_title">Tworzenie nowego obrazu</string>
    <string name="guide_create_1">Naciśnij +, a następnie \"Utwórz nowy obraz dysku\"</string>
    <string name="guide_create_2">Ustaw nazwę pliku i rozmiar (obsługuje MB, GB, GiB). Tworzenie odbywa się natychmiast.</string>
    <string name="guide_create_3">Po zamontowaniu sformatuj go z poziomu komputera (FAT32, exFAT lub NTFS).</string>
    <string name="guide_multi_title">Wiele urządzeń</string>
    <string name="guide_multi_body">Zamontuj do 8 urządzeń jednocześnie. Każde pojawia się jako osobne urządzenie USB na komputerze. Naciśnij kartę urządzenia, aby zmienić jego typ lub je usunąć.</string>
    <string name="guide_issues_title">Częste problemy</string>
    <string name="guide_issue_daemon">Daemon nie działa</string>
    <string name="guide_issue_daemon_fix">Uruchom ponownie urządzenie lub przejdź do Ustawień i naciśnij Uruchom ponownie daemon.</string>
    <string name="guide_issue_root">Root nieprzyznany</string>
    <string name="guide_issue_root_fix">Otwórz menedżer root (KSU/Magisk) i przyznaj tej aplikacji dostęp root.</string>
    <string name="guide_issue_usb">Komputer nie wykrywa USB</string>
    <string name="guide_issue_usb_fix">Podłącz ponownie kabel. Sprawdź, czy debugowanie USB nie nadpisuje trybu gadżetu.</string>
    <string name="guide_issue_appfuse">Proxy AppFuse</string>
    <string name="guide_issue_appfuse_fix">Twój menedżer plików pośredniczy w dostępie do pliku. Użyj innego menedżera plików (nie Google Files).</string>
