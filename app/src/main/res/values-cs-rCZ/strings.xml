    <string name="guide_what_title">Co tato aplikace dělá</string>
    <string name="guide_what_body">Promění váš telefon v USB disk. Když je telefon připojen k počítači přes USB, počítač vidí obraz disku na telefonu jako skutečné USB úložné zařízení. Můžete připojit soubory .img jako USB disky nebo soubory .iso jako CD mechaniky.</string>
    <string name="guide_before_title">Než začnete</string>
    <string name="guide_before_1">Vyžadován přístup root (KernelSU, Magisk nebo APatch)</string>
    <string name="guide_before_2">Udělte této aplikaci oprávnění root ve správci root</string>
    <string name="guide_before_3">Připojte telefon k počítači pomocí USB kabelu</string>
    <string name="guide_mount_title">Připojení obrazu disku</string>
    <string name="guide_mount_1">Klepněte na tlačítko + na hlavní obrazovce</string>
    <string name="guide_mount_2">Klepněte na \"Vybrat soubor obrazu disku\" a vyberte soubor .img nebo .iso</string>
    <string name="guide_mount_3">Vyberte typ: Čtení-Zápis (USB disk), Pouze pro čtení (chráněno proti zápisu) nebo CD-ROM (pro ISO)</string>
    <string name="guide_mount_4">Klepněte na \"Připojit\". Počítač detekuje nové USB zařízení během několika sekund.</string>
    <string name="guide_mount_5">Pro vysunutí: klepněte na ikonu vysunutí na kartě zařízení.</string>
    <string name="guide_create_title">Vytvoření nového obrazu</string>
    <string name="guide_create_1">Klepněte na + a poté na \"Vytvořit nový obraz disku\"</string>
    <string name="guide_create_2">Nastavte název souboru a velikost (podporuje MB, GB, GiB). Vytvoří se okamžitě.</string>
    <string name="guide_create_3">Po připojení ho naformátujte z počítače (FAT32, exFAT nebo NTFS).</string>
    <string name="guide_multi_title">Více zařízení</string>
    <string name="guide_multi_body">Připojte až 8 zařízení současně. Každé se na počítači zobrazí jako samostatné USB zařízení. Klepnutím na kartu zařízení změníte jeho typ nebo ho odeberete.</string>
    <string name="guide_issues_title">Časté problémy</string>
    <string name="guide_issue_daemon">Daemon neběží</string>
    <string name="guide_issue_daemon_fix">Restartujte zařízení nebo přejděte do Nastavení a klepněte na Restartovat daemon.</string>
    <string name="guide_issue_root">Root neudělen</string>
    <string name="guide_issue_root_fix">Otevřete správce root (KSU/Magisk) a udělte této aplikaci přístup root.</string>
    <string name="guide_issue_usb">Počítač nedetekuje USB</string>
    <string name="guide_issue_usb_fix">Znovu připojte kabel. Zkontrolujte, zda ladění USB nepřepisuje režim gadget.</string>
    <string name="guide_issue_appfuse">Proxy AppFuse</string>
    <string name="guide_issue_appfuse_fix">Váš správce souborů přistupuje k souboru přes proxy. Použijte jiného správce souborů (ne Google Files).</string>
