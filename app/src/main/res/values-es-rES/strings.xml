    <string name="guide_what_title">Qué hace esta app</string>
    <string name="guide_what_body">Convierte tu teléfono en una unidad USB. Cuando lo conectas a un ordenador por cable USB, el ordenador ve una imagen de disco de tu teléfono como un dispositivo de almacenamiento USB real. Puedes montar archivos .img como memorias USB o archivos .iso como unidades de CD.</string>
    <string name="guide_before_title">Antes de empezar</string>
    <string name="guide_before_1">Se requiere acceso root (KernelSU, Magisk o APatch)</string>
    <string name="guide_before_2">Concede permiso root a esta app en tu gestor de root</string>
    <string name="guide_before_3">Conecta tu teléfono a un ordenador mediante cable USB</string>
    <string name="guide_mount_title">Montar una imagen de disco</string>
    <string name="guide_mount_1">Pulsa el botón + en la pantalla principal</string>
    <string name="guide_mount_2">Pulsa \"Seleccionar imagen de disco\" y elige tu archivo .img o .iso</string>
    <string name="guide_mount_3">Selecciona el tipo: Lectura/Escritura (memoria USB), Solo lectura (protegido contra escritura) o CD-ROM (para ISOs)</string>
    <string name="guide_mount_4">Pulsa \"Montar\". El ordenador detectará un nuevo dispositivo USB en segundos.</string>
    <string name="guide_mount_5">Para expulsar: pulsa el icono de expulsión en la tarjeta del dispositivo.</string>
    <string name="guide_create_title">Crear una nueva imagen</string>
    <string name="guide_create_1">Pulsa +, luego \"Crear nueva imagen de disco\"</string>
    <string name="guide_create_2">Define el nombre y tamaño (acepta MB, GB, GiB). Se crea al instante.</string>
    <string name="guide_create_3">Después de montar, formatéalo desde el ordenador (FAT32, exFAT o NTFS).</string>
    <string name="guide_multi_title">Múltiples dispositivos</string>
    <string name="guide_multi_body">Monta hasta 8 dispositivos simultáneamente. Cada uno aparece como un dispositivo USB independiente en el ordenador. Pulsa una tarjeta de dispositivo para cambiar su tipo o eliminarlo.</string>
    <string name="guide_issues_title">Problemas comunes</string>
    <string name="guide_issue_daemon">El daemon no está en ejecución</string>
    <string name="guide_issue_daemon_fix">Reinicia tu dispositivo, o ve a Ajustes y pulsa Reiniciar daemon.</string>
    <string name="guide_issue_root">Root no concedido</string>
    <string name="guide_issue_root_fix">Abre tu gestor de root (KSU/Magisk) y concede acceso root a esta app.</string>
    <string name="guide_issue_usb">El ordenador no detecta el USB</string>
    <string name="guide_issue_usb_fix">Reconecta el cable. Comprueba que la depuración USB no esté anulando el modo gadget.</string>
    <string name="guide_issue_appfuse">Proxy AppFuse</string>
    <string name="guide_issue_appfuse_fix">Tu gestor de archivos está usando un proxy. Usa otro gestor de archivos (no Google Files).</string>
