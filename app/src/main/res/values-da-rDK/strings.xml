    <string name="guide_what_title">Hvad denne app gør</string>
    <string name="guide_what_body">Forvandler din telefon til et USB-drev. Når den er forbundet til en computer via USB, ser computeren en diskafbildning på din telefon som en rigtig USB-lagringsenhed. Du kan montere .img-filer som USB-nøgler eller .iso-filer som CD-drev.</string>
    <string name="guide_before_title">Inden du begynder</string>
    <string name="guide_before_1">Root-adgang påkrævet (KernelSU, Magisk eller APatch)</string>
    <string name="guide_before_2">Giv root-tilladelse til denne app i din root-manager</string>
    <string name="guide_before_3">Tilslut din telefon til en computer via USB-kabel</string>
    <string name="guide_mount_title">Montering af en diskafbildning</string>
    <string name="guide_mount_1">Tryk på +-knappen på hovedskærmen</string>
    <string name="guide_mount_2">Tryk på \"Vælg diskafbildningsfil\" og vælg din .img eller .iso</string>
    <string name="guide_mount_3">Vælg type: Læs-skriv (USB-nøgle), Skrivebeskyttet (skrivebeskyttet) eller CD-ROM (til ISO-filer)</string>
    <string name="guide_mount_4">Tryk på \"Montér\". Computeren registrerer en ny USB-enhed inden for sekunder.</string>
    <string name="guide_mount_5">For at skubbe ud: tryk på skub ud-ikonet på enhedskortet.</string>
    <string name="guide_create_title">Opret en ny afbildning</string>
    <string name="guide_create_1">Tryk på +, derefter \"Opret ny diskafbildning\"</string>
    <string name="guide_create_2">Angiv filnavn og størrelse (accepterer MB, GB, GiB). Oprettes øjeblikkeligt.</string>
    <string name="guide_create_3">Efter montering, formatér den fra computeren (FAT32, exFAT eller NTFS).</string>
    <string name="guide_multi_title">Flere enheder</string>
    <string name="guide_multi_body">Montér op til 8 enheder samtidigt. Hver vises som en separat USB-enhed på computeren. Tryk på et enhedskort for at ændre dets type eller fjerne det.</string>
    <string name="guide_issues_title">Almindelige problemer</string>
    <string name="guide_issue_daemon">Daemon kører ikke</string>
    <string name="guide_issue_daemon_fix">Genstart din enhed, eller gå til Indstillinger og tryk på Genstart daemon.</string>
    <string name="guide_issue_root">Root ikke tildelt</string>
    <string name="guide_issue_root_fix">Åbn din root-manager (KSU/Magisk) og giv denne app root-adgang.</string>
    <string name="guide_issue_usb">Computeren registrerer ikke USB</string>
    <string name="guide_issue_usb_fix">Tilslut kablet igen. Kontrollér, at USB-fejlsøgning ikke tilsidesætter gadget-tilstand.</string>
    <string name="guide_issue_appfuse">AppFuse-proxy</string>
    <string name="guide_issue_appfuse_fix">Din filvælger proxyer filen. Brug en anden filhåndtering (ikke Google Filer).</string>
