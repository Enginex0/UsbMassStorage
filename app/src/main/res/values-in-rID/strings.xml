    <string name="guide_what_title">Apa yang Dilakukan Aplikasi Ini</string>
    <string name="guide_what_body">Mengubah ponsel Anda menjadi drive USB. Saat terhubung ke komputer melalui USB, komputer melihat image disk di ponsel Anda sebagai perangkat penyimpanan USB sungguhan. Anda dapat memasang berkas .img sebagai USB flash drive atau berkas .iso sebagai drive CD.</string>
    <string name="guide_before_title">Sebelum Memulai</string>
    <string name="guide_before_1">Diperlukan akses root (KernelSU, Magisk, atau APatch)</string>
    <string name="guide_before_2">Berikan izin root ke aplikasi ini di pengelola root Anda</string>
    <string name="guide_before_3">Hubungkan ponsel ke komputer dengan kabel USB</string>
    <string name="guide_mount_title">Memasang Image Disk</string>
    <string name="guide_mount_1">Ketuk tombol + di layar utama</string>
    <string name="guide_mount_2">Ketuk \"Pilih berkas image disk\" dan pilih berkas .img atau .iso Anda</string>
    <string name="guide_mount_3">Pilih jenis: Baca-Tulis (USB flash drive), Hanya-Baca (dilindungi tulis), atau CD-ROM (untuk ISO)</string>
    <string name="guide_mount_4">Ketuk \"Pasang\". Komputer mendeteksi perangkat USB baru dalam hitungan detik.</string>
    <string name="guide_mount_5">Untuk mengeluarkan: ketuk ikon keluarkan di kartu perangkat.</string>
    <string name="guide_create_title">Membuat Image Baru</string>
    <string name="guide_create_1">Ketuk +, lalu \"Buat image disk baru\"</string>
    <string name="guide_create_2">Atur nama berkas dan ukuran (menerima MB, GB, GiB). Dibuat secara instan.</string>
    <string name="guide_create_3">Setelah dipasang, format dari komputer (FAT32, exFAT, atau NTFS).</string>
    <string name="guide_multi_title">Beberapa Perangkat</string>
    <string name="guide_multi_body">Pasang hingga 8 perangkat secara bersamaan. Masing-masing muncul sebagai perangkat USB terpisah di komputer. Ketuk kartu perangkat untuk mengubah jenisnya atau menghapusnya.</string>
    <string name="guide_issues_title">Masalah Umum</string>
    <string name="guide_issue_daemon">Daemon tidak berjalan</string>
    <string name="guide_issue_daemon_fix">Mulai ulang perangkat Anda, atau buka Pengaturan dan ketuk Mulai Ulang Daemon.</string>
    <string name="guide_issue_root">Root tidak diberikan</string>
    <string name="guide_issue_root_fix">Buka pengelola root Anda (KSU/Magisk) dan berikan akses root ke aplikasi ini.</string>
    <string name="guide_issue_usb">Komputer tidak mendeteksi USB</string>
    <string name="guide_issue_usb_fix">Sambungkan kembali kabel. Periksa apakah debug USB tidak menimpa mode gadget.</string>
    <string name="guide_issue_appfuse">AppFuse proxy</string>
    <string name="guide_issue_appfuse_fix">Pemilih berkas Anda mem-proxy berkas tersebut. Gunakan pengelola berkas lain (bukan Google Files).</string>
