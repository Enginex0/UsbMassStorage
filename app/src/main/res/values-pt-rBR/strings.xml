    <string name="guide_what_title">O que este app faz</string>
    <string name="guide_what_body">Transforma seu celular em um pendrive USB. Quando conectado a um computador por cabo USB, o computador enxerga uma imagem de disco no seu celular como um dispositivo de armazenamento USB real. Você pode montar arquivos .img como pendrives ou arquivos .iso como drives de CD.</string>
    <string name="guide_before_title">Antes de começar</string>
    <string name="guide_before_1">Acesso root necessário (KernelSU, Magisk ou APatch)</string>
    <string name="guide_before_2">Conceda permissão root a este app no seu gerenciador root</string>
    <string name="guide_before_3">Conecte seu celular a um computador por cabo USB</string>
    <string name="guide_mount_title">Montando uma imagem de disco</string>
    <string name="guide_mount_1">Toque no botão + na tela principal</string>
    <string name="guide_mount_2">Toque em \"Selecionar imagem de disco\" e escolha seu arquivo .img ou .iso</string>
    <string name="guide_mount_3">Selecione o tipo: Leitura/Gravação (pendrive), Somente leitura (protegido contra gravação) ou CD-ROM (para ISOs)</string>
    <string name="guide_mount_4">Toque em \"Montar\". O computador detecta um novo dispositivo USB em segundos.</string>
    <string name="guide_mount_5">Para ejetar: toque no ícone de ejeção no cartão do dispositivo.</string>
    <string name="guide_create_title">Criando uma nova imagem</string>
    <string name="guide_create_1">Toque em +, depois em \"Criar nova imagem de disco\"</string>
    <string name="guide_create_2">Defina o nome e o tamanho (aceita MB, GB, GiB). Criação instantânea.</string>
    <string name="guide_create_3">Após montar, formate-o pelo computador (FAT32, exFAT ou NTFS).</string>
    <string name="guide_multi_title">Múltiplos dispositivos</string>
    <string name="guide_multi_body">Monte até 8 dispositivos simultaneamente. Cada um aparece como um dispositivo USB separado no computador. Toque em um cartão de dispositivo para alterar o tipo ou removê-lo.</string>
    <string name="guide_issues_title">Problemas comuns</string>
    <string name="guide_issue_daemon">Daemon não está em execução</string>
    <string name="guide_issue_daemon_fix">Reinicie seu dispositivo, ou vá em Configurações e toque em Reiniciar daemon.</string>
    <string name="guide_issue_root">Root não concedido</string>
    <string name="guide_issue_root_fix">Abra seu gerenciador root (KSU/Magisk) e conceda acesso root a este app.</string>
    <string name="guide_issue_usb">O computador não detecta o USB</string>
    <string name="guide_issue_usb_fix">Reconecte o cabo. Verifique se a depuração USB não está sobrepondo o modo gadget.</string>
    <string name="guide_issue_appfuse">Proxy AppFuse</string>
    <string name="guide_issue_appfuse_fix">Seu gerenciador de arquivos está usando um proxy. Use outro gerenciador de arquivos (não o Google Files).</string>
