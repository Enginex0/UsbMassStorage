    <string name="guide_what_title">Τι κάνει αυτή η εφαρμογή</string>
    <string name="guide_what_body">Μετατρέπει το τηλέφωνό σας σε μονάδα USB. Όταν συνδεθεί σε υπολογιστή μέσω USB, ο υπολογιστής βλέπει μια εικόνα δίσκου στο τηλέφωνό σας ως πραγματική συσκευή αποθήκευσης USB. Μπορείτε να προσαρτήσετε αρχεία .img ως USB sticks ή αρχεία .iso ως μονάδες CD.</string>
    <string name="guide_before_title">Πριν ξεκινήσετε</string>
    <string name="guide_before_1">Απαιτείται πρόσβαση root (KernelSU, Magisk ή APatch)</string>
    <string name="guide_before_2">Εκχωρήστε δικαιώματα root σε αυτή την εφαρμογή στον διαχειριστή root</string>
    <string name="guide_before_3">Συνδέστε το τηλέφωνό σας σε υπολογιστή μέσω καλωδίου USB</string>
    <string name="guide_mount_title">Προσάρτηση εικόνας δίσκου</string>
    <string name="guide_mount_1">Πατήστε το κουμπί + στην κύρια οθόνη</string>
    <string name="guide_mount_2">Πατήστε \"Επιλογή αρχείου εικόνας δίσκου\" και επιλέξτε το .img ή .iso σας</string>
    <string name="guide_mount_3">Επιλέξτε τύπο: Ανάγνωση-Εγγραφή (USB stick), Μόνο ανάγνωση (προστασία εγγραφής) ή CD-ROM (για ISO)</string>
    <string name="guide_mount_4">Πατήστε \"Προσάρτηση\". Ο υπολογιστής εντοπίζει μια νέα συσκευή USB μέσα σε δευτερόλεπτα.</string>
    <string name="guide_mount_5">Για εξαγωγή: πατήστε το εικονίδιο εξαγωγής στην κάρτα συσκευής.</string>
    <string name="guide_create_title">Δημιουργία νέας εικόνας</string>
    <string name="guide_create_1">Πατήστε +, μετά \"Δημιουργία νέας εικόνας δίσκου\"</string>
    <string name="guide_create_2">Ορίστε όνομα αρχείου και μέγεθος (δέχεται MB, GB, GiB). Δημιουργείται αμέσως.</string>
    <string name="guide_create_3">Μετά την προσάρτηση, διαμορφώστε τη από τον υπολογιστή (FAT32, exFAT ή NTFS).</string>
    <string name="guide_multi_title">Πολλαπλές συσκευές</string>
    <string name="guide_multi_body">Προσαρτήστε έως 8 συσκευές ταυτόχρονα. Κάθε μία εμφανίζεται ως ξεχωριστή συσκευή USB στον υπολογιστή. Πατήστε μια κάρτα συσκευής για να αλλάξετε τον τύπο ή να την αφαιρέσετε.</string>
    <string name="guide_issues_title">Συνηθισμένα προβλήματα</string>
    <string name="guide_issue_daemon">Ο daemon δεν εκτελείται</string>
    <string name="guide_issue_daemon_fix">Επανεκκινήστε τη συσκευή σας ή μεταβείτε στις Ρυθμίσεις και πατήστε Επανεκκίνηση daemon.</string>
    <string name="guide_issue_root">Root δεν εκχωρήθηκε</string>
    <string name="guide_issue_root_fix">Ανοίξτε τον διαχειριστή root (KSU/Magisk) και εκχωρήστε πρόσβαση root σε αυτή την εφαρμογή.</string>
    <string name="guide_issue_usb">Ο υπολογιστής δεν εντοπίζει USB</string>
    <string name="guide_issue_usb_fix">Ξανασυνδέστε το καλώδιο. Ελέγξτε ότι η αποσφαλμάτωση USB δεν παρακάμπτει τη λειτουργία gadget.</string>
    <string name="guide_issue_appfuse">AppFuse proxy</string>
    <string name="guide_issue_appfuse_fix">Ο επιλογέας αρχείων σας κάνει proxy το αρχείο. Χρησιμοποιήστε διαφορετικό διαχειριστή αρχείων (όχι Google Files).</string>
